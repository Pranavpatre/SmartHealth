{
  "hosting": [
    {
      "target": "dashboard",
      "public": "frontend/dashboard/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "@(/|/index.html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|png|jpg|jpeg|svg|gif|ico|webp|json)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "field-app",
      "public": "frontend/field-app/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "@(/|/index.html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|woff|ttf|png|jpg|jpeg|svg|gif|ico|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    }
  ]
}