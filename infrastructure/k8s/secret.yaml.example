# Copy to secret.yaml, fill in real values, then:
#   kubectl apply -f secret.yaml
# NEVER commit secret.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: smarthealth-secrets
  namespace: smarthealth
type: Opaque
stringData:
  POSTGRES_USER: "smarthealth"
  POSTGRES_PASSWORD: "CHANGE_ME"
  REDIS_PASSWORD: "CHANGE_ME"
  SECRET_KEY: "CHANGE_ME_32_CHAR_RANDOM_STRING"
  SENTRY_DSN: ""
  WHATSAPP_TOKEN: ""
  WHATSAPP_PHONE_NUMBER_ID: ""
  WHATSAPP_VERIFY_TOKEN: ""
  GEMINI_API_KEY: ""
